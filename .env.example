# Copy to `.env` on the Droplet (never commit `.env`).
# Local dev: leave unset or use empty MYSQL_ROOT_PASSWORD with MYSQL_ALLOW_EMPTY_PASSWORD=yes (default in compose).

# ── Required on a public server ─────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-me-to-a-long-random-string
MYSQL_ALLOW_EMPTY_PASSWORD=no

# Optional: pin host port for MySQL (default 3306). Only bind 127.0.0.1 in firewall if you expose it.
# DB_PORT=3306
