# Stage 1: Build Flutter Web
FROM ubuntu:22.04 AS build-env

# Install dependencies
RUN apt-get update && apt-get install -y curl git unzip xz-utils libglu1-mesa

# Install Flutter
RUN git clone https://github.com/flutter/flutter.git /usr/local/flutter
ENV PATH="/usr/local/flutter/bin:/usr/local/flutter/bin/cache/dart-sdk/bin:${PATH}"

# Build the project
WORKDIR /app
COPY . .

# Build argument for the API base URL (no trailing slash). Rebuild with
# `docker compose build --no-cache web` after changing API_URL — the Flutter
# step is heavily cached.
ARG API_URL=https://api.medtechinventorysystem.org
RUN flutter build web --release --dart-define=API_BASE_URL=$API_URL

# Stage 2: Serve with Nginx
FROM nginx:alpine
COPY --from=build-env /app/build/web /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
